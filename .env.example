# ─────────────────────────────────────────────────────────────────────────────
# Tribe Index — environment variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# Postgres connection string (Neon). Use the pooled/serverless connection URL.
# Example: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=

# Auth.js (NextAuth v5) secret used to sign/encrypt tokens and cookies.
# Generate one with: openssl rand -base64 32  (or: npx auth secret)
AUTH_SECRET=

# Canonical URL of the deployment, used by Auth.js to build callback URLs.
# Local: http://localhost:3000  ·  Production: https://your-app.vercel.app
# On Vercel this can usually be omitted (auto-detected), but set it if needed.
AUTH_URL=http://localhost:3000

# Resend API key — sends the passwordless magic-link sign-in emails.
# Create one at https://resend.com/api-keys
RESEND_API_KEY=

# The "from" address magic-link emails are sent as. Must be on a domain
# verified in your Resend account (e.g. "Tribe Index <login@yourdomain.com>").
AUTH_EMAIL_FROM=
